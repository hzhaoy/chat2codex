# Run `bun run setup:feishu` to create and connect a Feishu/Lark app automatically,
# or fill these manually from the Feishu/Lark developer console.
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=
# Written by setup when available. Used to ignore group messages that do not
# explicitly mention this bot.
FEISHU_BOT_OPEN_ID=

# Use "feishu" for 飞书, "lark" for Lark global.
LARK_DOMAIN=feishu

# The directory Codex should work in by default.
CODEX_WORKDIR=/absolute/path/to/your/repo
# Use an absolute path for background services, for example the output of
# `command -v codex`.
CODEX_BIN=codex
CODEX_SANDBOX=workspace-write
CODEX_APPROVAL_POLICY=never
CODEX_MODEL=
CODEX_SKIP_GIT_REPO_CHECK=false
# Group chats are constrained to CODEX_WORKDIR unless this comma-separated list is set.
# Direct messages are not constrained by this setting.
CODEX_GROUP_ALLOWED_ROOTS=

# Access control. Direct messages are enabled by default; groups must be
# explicitly enabled and allowlisted by chat_id.
ALLOW_DIRECT_MESSAGES=true
ALLOW_GROUPS=false
ALLOWED_CHAT_IDS=
ALLOWED_USER_IDS=

ATTACHMENT_DOWNLOAD_DIR=.data/attachments
BRIDGE_STATE_PATH=.data/state.json
LOG_LEVEL=info
